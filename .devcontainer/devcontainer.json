{
  "name": "BookFast Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-vscode.extension-pack-for-node",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "forwardPorts": [3000, 5000, 1433],
  "postCreateCommand": "dotnet restore src/api/BookFast.API && npm install --prefix src/frontend"
}
