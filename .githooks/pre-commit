#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
script_path="$repo_root/scripts/run-api-format-check.ps1"

if [ ! -f "$script_path" ]; then
  echo "Missing script: $script_path" >&2
  exit 1
fi

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File "$script_path"
fi

if command -v powershell >/dev/null 2>&1; then
  exec powershell -NoProfile -ExecutionPolicy Bypass -File "$script_path"
fi

if command -v wslpath >/dev/null 2>&1; then
  windows_script_path="$(wslpath -w "$script_path")"

  if command -v pwsh.exe >/dev/null 2>&1; then
    exec pwsh.exe -NoProfile -ExecutionPolicy Bypass -File "$windows_script_path"
  fi

  if command -v powershell.exe >/dev/null 2>&1; then
    exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$windows_script_path"
  fi
fi

echo "PowerShell is required to run the BookFast pre-commit hook." >&2
exit 1
